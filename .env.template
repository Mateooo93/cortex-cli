# API Keys for vix
# Copy this file to .env and fill in your keys

ANTHROPIC_API_KEY=your-anthropic-api-key-here
OPENAI_API_KEY=your-openai-api-key-here
GOOGLE_API_KEY=your-google-api-key-here

# PostHog telemetry (optional). Read at build time and embedded into the binary
# via -ldflags (see script/build.sh); not read at runtime. Leave empty to ship
# without analytics.
VIX_POSTHOG_API_KEY=

# Discord release announcements (optional, used by script/publish.sh)
DISCORD_WEBHOOK_URL=

# --- Release / publish tokens (local dev + mirror in GitHub Actions secrets) ---
#
# GitHub Packages (default for @mateooo93/cortex):
#   CI uses GITHUB_TOKEN automatically (packages: write permission).
#   Local: create a PAT (classic) with write:packages at
#     https://github.com/settings/tokens
#   Export as NODE_AUTH_TOKEN or GITHUB_TOKEN before ./script/publish-npm.sh
#
# npmjs.org (optional legacy mateooo93-cortex via --registry npmjs):
#   Requires npm 2FA + Automation token (or granular w/ bypass 2FA).
#   CI secret name: NPM_TOKEN
NPM_TOKEN=

# Optional: opens PRs to microsoft/winget-pkgs (GitHub PAT, public_repo)
# CI secret name: WINGET_TOKEN
WINGET_TOKEN=

# Optional: updates homebrew-cortex tap on release
# CI secret name: HOMEBREW_TAP_TOKEN
HOMEBREW_TAP_TOKEN=